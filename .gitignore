# https://git-scm.com/docs/gitignore
# https://help.github.com/articles/ignoring-files
# Example .gitignore files: https://github.com/github/gitignore
/bower_components/
/node_modules/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# Environment
.env

# Generated data (cached API responses and outputs)
data/cfr_cache/*.json
data/fact_graph_defs/*.json
data/cost_log.json

# Keep directory structure
!data/cfr_cache/.gitkeep
!data/fact_graph_defs/.gitkeep
!data/test_cases/.gitkeep

# mypy
.mypy_cache/

# pytest
.pytest_cache/
